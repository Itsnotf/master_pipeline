# Recommended .gitignore for this Python project
# Use Git LFS for large model files (e.g., *.pt) instead of committing them.

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
venv/
ENV/
env/
.venv/
.env
.env.*

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Testing / coverage
.pytest_cache/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints

# Logs
*.log

# Python compiled
*.pyc
*.pyo
*.pyd

# Lock files
Pipfile.lock
poetry.lock

# Large ML artifacts (do not commit model weights)
*.pt
*.pth
*.ckpt
*.h5
*.onnx
*.bin

# Project-specific model and output folders
ear/model/
hand/model/
output/
ear/runs/
**/runs/

# Local settings
local_settings.py
instance/
